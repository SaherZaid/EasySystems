@page "/pricing"

<PageTitle>Pricing | EasySystems</PageTitle>

<div class="pricing-page">

    <section class="pricing-hero">
        <p class="eyebrow">EasySystems</p>
        <h1>Simple pricing for growing businesses</h1>
        <p>
            Choose the package that matches your business stage.
            Start small or launch a complete professional online store.
        </p>
    </section>

    <section class="pricing-grid">

        <article class="price-card">
            <h3>Starter</h3>
            <p class="price-value">4,900 kr</p>
            <p class="price-desc">Perfect for new small businesses starting online.</p>

            <ul>
                <li>✓ Modern landing store</li>
                <li>✓ Up to 10 products</li>
                <li>✓ Mobile friendly</li>
                <li>✓ Contact / order form</li>
                <li>✓ Basic SEO setup</li>
                <li>✓ 7 days delivery</li>
            </ul>

            <a href="/create-store" class="price-btn-light">Choose Starter</a>
        </article>

        <article class="price-card featured-price">
            <span class="popular-badge">Most Popular</span>

            <h3>Business</h3>
            <p class="price-value">9,900 kr</p>
            <p class="price-desc">For businesses ready to sell seriously online.</p>

            <ul>
                <li>✓ Full online store</li>
                <li>✓ Up to 75 products</li>
                <li>✓ Payment integration</li>
                <li>✓ Categories & filters</li>
                <li>✓ Multi-language option</li>
                <li>✓ 14 days delivery</li>
                <li>✓ Priority support</li>
            </ul>

            <a href="/create-store" class="price-btn-main">Choose Business</a>
        </article>

        <article class="price-card">
            <h3>Premium</h3>
            <p class="price-value">19,900 kr</p>
            <p class="price-desc">For brands that want a premium full solution.</p>

            <ul>
                <li>✓ Advanced custom store</li>
                <li>✓ Unlimited products</li>
                <li>✓ Premium UI/UX design</li>
                <li>✓ Advanced features</li>
                <li>✓ Speed optimization</li>
                <li>✓ Growth strategy</li>
                <li>✓ VIP support</li>
            </ul>

            <a href="/create-store" class="price-btn-light">Choose Premium</a>
        </article>

    </section>

    <section class="pricing-compare">

        <div class="section-heading">
            <p class="eyebrow">Compare</p>
            <h2>What’s included</h2>
        </div>

        <div class="compare-table">

            <div class="compare-head">
                <span>Feature</span>
                <span>Starter</span>
                <span>Business</span>
                <span>Premium</span>
            </div>

            <div class="compare-row">
                <span>Products</span>
                <span>10</span>
                <span>75</span>
                <span>Unlimited</span>
            </div>

            <div class="compare-row">
                <span>Online Payments</span>
                <span>—</span>
                <span>✓</span>
                <span>✓</span>
            </div>

            <div class="compare-row">
                <span>Custom Design</span>
                <span>Basic</span>
                <span>Good</span>
                <span>Premium</span>
            </div>

            <div class="compare-row">
                <span>Languages</span>
                <span>1</span>
                <span>2</span>
                <span>Unlimited</span>
            </div>

            <div class="compare-row">
                <span>Support</span>
                <span>Standard</span>
                <span>Priority</span>
                <span>VIP</span>
            </div>

        </div>

    </section>

    <section class="pricing-faq">

        <div class="section-heading">
            <p class="eyebrow">FAQ</p>
            <h2>Questions clients ask</h2>
        </div>

        <div class="faq-grid">

            <div>
                <h3>Can I upgrade later?</h3>
                <p>Yes. You can start small and upgrade anytime.</p>
            </div>

            <div>
                <h3>Do you help after launch?</h3>
                <p>Yes, support options are available after delivery.</p>
            </div>

            <div>
                <h3>Can I request custom features?</h3>
                <p>Yes, especially in Business and Premium plans.</p>
            </div>

            <div>
                <h3>How do we start?</h3>
                <p>Choose a package and submit your request form.</p>
            </div>

        </div>

    </section>

    <section class="pricing-cta">
        <h2>Ready to launch your store?</h2>
        <p>Choose your package and send your request today.</p>
        <a href="/create-store" class="price-btn-main">Start Now</a>
    </section>

</div>