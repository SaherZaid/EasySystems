@page "/create-store"
@rendermode InteractiveServer
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Create Store</PageTitle>

<div class="store-page">

    <section class="store-hero-pro">
        <p class="eyebrow">EasySystems</p>
        <h1>Build your dream online store</h1>
        <p>
            Tell us exactly what you need and we’ll create the right solution for your business.
        </p>
    </section>

    <section class="pro-form-card">

        <h2>Business Information</h2>

        <div class="pro-grid">
            <input @bind="storeName"
                   class="@GetErrorClass(storeName)"
                   placeholder="Store name *" />

            @if (IsEmpty(storeName))
            {
                <small class="field-error">Store name is required</small>
            }
            <input @bind="businessType"
                   class="@GetErrorClass(businessType)"
                   placeholder="What do you sell? *" />

            @if (IsEmpty(businessType))
            {
                <small class="field-error">Business type is required</small>
            }

            <select @bind="productCount">
                <option>1-20 products</option>
                <option>20-100 products</option>
                <option>100+ products</option>
            </select>

            <select @bind="languages">
                <option>Swedish</option>
                <option>Arabic</option>
                <option>English</option>
                <option>Arabic + Swedish</option>
                <option>Arabic + Swedish + English</option>
            </select>
        </div>

        <h2>Design & Branding</h2>

        <div class="pro-grid">
            <select @bind="hasLogo">
                <option>I have logo</option>
                <option>I need logo</option>
            </select>

            <input @bind="brandColors"
                   class="@GetErrorClass(brandColors)"
                   placeholder="Preferred colors *" />

            @if (IsEmpty(brandColors))
            {
                <small class="field-error">Please enter colors</small>
            }
            <input @bind="exampleSites"
                   class="@GetErrorClass(exampleSites)"
                   placeholder="Sites you like *" />

            @if (IsEmpty(exampleSites))
            {
                <small class="field-error">Please add examples</small>
            }

            <select @bind="designStyle">
                <option>Luxury</option>
                <option>Modern</option>
                <option>Simple</option>
                <option>Bold</option>
            </select>
        </div>

        <h2>Store Features</h2>

        <div class="pro-grid">
            <select @bind="payment">
                <option>Yes online payment</option>
                <option>No</option>
            </select>

            <select @bind="shipping">
                <option>Need shipping</option>
                <option>No shipping</option>
            </select>

            <select @bind="accounts">
                <option>Need customer accounts</option>
                <option>No accounts needed</option>
            </select>

            <select @bind="discounts">
                <option>Need discount codes</option>
                <option>No discounts</option>
            </select>
        </div>

        <h2>Business Plan</h2>

        <div class="pro-grid">
            <input @bind="budget"
                   class="@GetErrorClass(budget)"
                   placeholder="Budget (SEK) *" />

            @if (IsEmpty(budget))
            {
                <small class="field-error">Budget is required</small>
            }
            <input @bind="launchDate"
                   class="@GetErrorClass(launchDate)"
                   placeholder="Preferred launch date *" />

            @if (IsEmpty(launchDate))
            {
                <small class="field-error">Launch date required</small>
            }

            <select @bind="packageName">
                <option>Starter</option>
                <option>Business</option>
                <option>Premium</option>
            </select>

            <input @bind="domain"
                   class="@GetErrorClass(domain)"
                   placeholder="Do you have domain? *" />

            @if (IsEmpty(domain))
            {
                <small class="field-error">Please answer this field</small>
            }
        </div>

        <h2>Extra Notes</h2>

        <textarea @bind="notes"
                  class="@GetErrorClass(notes)"
                  placeholder="Write anything important here... *"></textarea>

        @if (IsEmpty(notes))
        {
            <small class="field-error">Please write notes</small>
        }

        <button class="submit-btn-pro"
                @onclick="SubmitRequest"
                disabled="@isLoading">

            @(isLoading ? "Sending Request..." : "Submit Store Request")

        </button>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="success-msg">@message</p>
        }

    </section>

</div>

@code {

    string storeName = "";
    string businessType = "";
    string productCount = "1-20 products";
    string languages = "Swedish";
    string hasLogo = "I have logo";
    string brandColors = "";
    string exampleSites = "";
    string designStyle = "Modern";
    string payment = "Yes online payment";
    string shipping = "Need shipping";
    string accounts = "Need customer accounts";
    string discounts = "Need discount codes";
    string budget = "";
    string launchDate = "";
    string packageName = "Business";
    string domain = "";
    string notes = "";

    string message = "";
    bool isLoading = false;

    bool triedSubmit = false;

    bool IsEmpty(string value)
    {
        return triedSubmit &&
               string.IsNullOrWhiteSpace(value);
    }

    string GetErrorClass(string value)
    {
        return IsEmpty(value)
            ? "input-error"
            : "";
    }

    async Task SubmitRequest()
    {

        triedSubmit = true;

        message = "";

        if (!ValidateForm())
        {
            message = "Please complete all required fields.";
            return;
        }

        isLoading = true;

        var token = await JS.InvokeAsync<string>(
            "localStorage.getItem",
            "authToken");

        using var req = new HttpRequestMessage(
            HttpMethod.Post,
            "https://localhost:7066/api/StoreRequests");

        req.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        req.Content = JsonContent.Create(new
        {
            storeName,
            businessType,
            packageName,
            notes,
            answers = new[]
            {
            new { question = "Product Count", answer = productCount },
            new { question = "Languages", answer = languages },
            new { question = "Logo", answer = hasLogo },
            new { question = "Colors", answer = brandColors },
            new { question = "Example Sites", answer = exampleSites },
            new { question = "Design Style", answer = designStyle },
            new { question = "Payment", answer = payment },
            new { question = "Shipping", answer = shipping },
            new { question = "Accounts", answer = accounts },
            new { question = "Discounts", answer = discounts },
            new { question = "Budget", answer = budget },
            new { question = "Launch Date", answer = launchDate },
            new { question = "Domain", answer = domain }
        }
        });

        var response = await Http.SendAsync(req);

        isLoading = false;

        if (response.IsSuccessStatusCode)
        {
            message = "Your request has been sent successfully ✔";

            ResetForm();
        }
        else
        {
            message = "Failed to submit request.";
        }
    }

    bool ValidateForm()
    {
        return
            !string.IsNullOrWhiteSpace(storeName) &&
            !string.IsNullOrWhiteSpace(businessType) &&
            !string.IsNullOrWhiteSpace(brandColors) &&
            !string.IsNullOrWhiteSpace(exampleSites) &&
            !string.IsNullOrWhiteSpace(budget) &&
            !string.IsNullOrWhiteSpace(launchDate) &&
            !string.IsNullOrWhiteSpace(domain) &&
            !string.IsNullOrWhiteSpace(notes);
    }

    void ResetForm()
    {
        triedSubmit = false;
        storeName = "";
        businessType = "";
        productCount = "1-20 products";
        languages = "Swedish";
        hasLogo = "I have logo";
        brandColors = "";
        exampleSites = "";
        designStyle = "Modern";
        payment = "Yes online payment";
        shipping = "Need shipping";
        accounts = "Need customer accounts";
        discounts = "Need discount codes";
        budget = "";
        launchDate = "";
        packageName = "Business";
        domain = "";
        notes = "";
    }

}