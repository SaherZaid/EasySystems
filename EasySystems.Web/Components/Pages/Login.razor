@page "/login"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject EasySystems.Web.Services.AuthStateService Auth


<PageTitle>Login</PageTitle>

<div class="auth-page">

    <section class="auth-card">

        <div class="auth-left">
            <p class="eyebrow">EasySystems</p>
            <h1>Login instantly</h1>
            <p>
                No password needed. Enter your email, receive a secure code,
                and access your dashboard in seconds.
            </p>

            <ul>
                <li>✓ Fast passwordless login</li>
                <li>✓ Secure email code</li>
                <li>✓ Access requests dashboard</li>
                <li>✓ Admin access by role</li>
            </ul>
        </div>

        <div class="auth-right">

            <h2>Login</h2>

            <input @bind="email" placeholder="Email address" />

            <button class="auth-btn-secondary" @onclick="SendCode">
                Send login code
            </button>

            @if (!string.IsNullOrWhiteSpace(devCode))
            {
                <div class="dev-code-box">
                    Test code: <strong>@devCode</strong>
                </div>
            }

            <input @bind="code" placeholder="Enter code" />

            <button class="auth-btn" @onclick="LoginWithCode">
                Login now
            </button>

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <p class="auth-message">@message</p>
            }

            <p class="auth-link">
                No account?
                <a href="/register">Create account</a>
            </p>

        </div>

    </section>

</div>

@code {
    private string email = "";
    private string code = "";
    private string devCode = "";
    private string message = "";

    private async Task SendCode()
    {
        var response = await Http.PostAsJsonAsync(
            "https://localhost:7066/api/Auth/send-code",
            email);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<SendCodeResponse>();

            devCode = result?.Code ?? "";
            code = devCode;

            message = "Login code created.";
        }
        else
        {
            message = "Could not send login code.";
        }
    }

    private async Task LoginWithCode()
    {
        var response = await Http.PostAsJsonAsync(
            "https://localhost:7066/api/Auth/verify-code",
            new
            {
                Email = email,
                Code = code
            });

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<LoginResponse>();

            if (result is not null)
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "authToken", result.Token);
                await JS.InvokeVoidAsync("localStorage.setItem", "userRole", result.Role);
                await JS.InvokeVoidAsync("localStorage.setItem", "userEmail", result.Email);

                Auth.SetUser(true, result.Role);
            }

            message = "Login successful.";

            await Task.Delay(700);
            Nav.NavigateTo("/dashboard");
        }
        else
        {
            message = "Invalid or expired code.";
        }
    }

    public class SendCodeResponse
    {
        public string Message { get; set; } = "";
        public string Code { get; set; } = "";
    }

    public class LoginResponse
    {
        public string Email { get; set; } = "";
        public string Role { get; set; } = "";
        public string Token { get; set; } = "";
    }
}