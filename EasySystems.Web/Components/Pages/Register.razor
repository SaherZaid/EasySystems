@page "/register"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Create Account</PageTitle>

<div class="auth-page">

    <section class="auth-card">

        <div class="auth-left">
            <p class="eyebrow">EasySystems</p>
            <h1>Create your account</h1>
            <p>
                Join EasySystems and request your online store, track progress,
                and manage everything in one place.
            </p>

            <ul>
                <li>✓ Track store requests</li>
                <li>✓ Fast login with email code</li>
                <li>✓ Dashboard access</li>
                <li>✓ Professional support</li>
            </ul>
        </div>

        <div class="auth-right">

            <h2>Register</h2>

            <input @bind="model.FirstName" placeholder="First name" />
            <input @bind="model.LastName" placeholder="Last name" />
            <input @bind="model.Email" placeholder="Email address" />
            <input @bind="model.PhoneNumber" placeholder="Phone number" />

            <button class="auth-btn" @onclick="SubmitRegister">
                Create account
            </button>

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <p class="auth-message">@message</p>
            }

            <p class="auth-link">
                Already have an account?
                <a href="/login">Login</a>
            </p>

        </div>

    </section>

</div>

@code {
    private string message = "";

    private RegisterModel model = new();

    private async Task SubmitRegister()
    {
        var response = await Http.PostAsJsonAsync(
            "https://localhost:7066/api/Auth/register",
            model);

        if (response.IsSuccessStatusCode)
        {
            message = "Account created successfully.";
            await Task.Delay(800);
            Nav.NavigateTo("/login");
        }
        else
        {
            message = "Could not create account.";
        }
    }

    public class RegisterModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string PhoneNumber { get; set; } = "";
    }
}