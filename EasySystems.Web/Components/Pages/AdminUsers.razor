@page "/admin/users"
@rendermode InteractiveServer
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Users Management | EasySystems</PageTitle>

<div class="users-pro-page">

    <section class="users-hero">

        <div>
            <p class="eyebrow">Super Admin Panel</p>
            <h1>Users Management</h1>
            <p>Manage accounts, roles, permissions and search users instantly.</p>
        </div>

        <button class="users-refresh-btn" @onclick="LoadUsers">
            Refresh
        </button>

    </section>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="users-alert">
            @message
        </div>
    }

    <section class="users-stats-grid">

        <div class="users-stat-card">
            <span>@users.Count</span>
            <p>Total Users</p>
        </div>

        <div class="users-stat-card">
            <span>@users.Count(x => x.Role == "User")</span>
            <p>Users</p>
        </div>

        <div class="users-stat-card">
            <span>@users.Count(x => x.Role == "Admin")</span>
            <p>Admins</p>
        </div>

        <div class="users-stat-card">
            <span>@users.Count(x => x.Role == "SuperAdmin")</span>
            <p>Super Admins</p>
        </div>

    </section>

    <section class="users-main-panel">

        <div class="users-toolbar">

            <input class="users-search"
                   @bind="search"
                   @bind:event="oninput"
                   placeholder="Search name, email, role..." />

            <select class="users-filter"
                    @bind="selectedRole">

                <option value="">All Roles</option>
                <option value="User">User</option>
                <option value="Admin">Admin</option>
                <option value="SuperAdmin">SuperAdmin</option>

            </select>

            <span class="users-result-count">
                @FilteredUsers.Count() results
            </span>

        </div>

        @if (isLoading)
        {
            <div class="users-empty">
                Loading users...
            </div>
        }
        else if (!FilteredUsers.Any())
        {
            <div class="users-empty">
                No users found.
            </div>
        }
        else
        {
            <div class="users-list">

                @foreach (var user in FilteredUsers)
                {
                    <article class="user-pro-card">

                        <div class="user-left">

                            <div class="user-avatar">
                                @GetInitial(user.FullName)
                            </div>

                            <div class="user-meta">
                                <h3>@user.FullName</h3>
                                <p>@user.Email</p>

                                <div class="user-badges">

                                    <span class="role-badge @GetRoleClass(user.Role)">
                                        @user.Role
                                    </span>

                                    <span class="verify-badge @(user.IsEmailVerified ? "ok" : "no")">
                                        @(user.IsEmailVerified ? "Verified" : "Not Verified")
                                    </span>

                                </div>

                            </div>

                        </div>

                        <div class="user-right">

                            <select class="role-select"
                                    @bind="user.SelectedRole">

                                <option>User</option>
                                <option>Admin</option>
                                <option>SuperAdmin</option>

                            </select>

                            <button class="save-role-btn"
                                    disabled="@(user.SelectedRole == user.Role)"
                                    @onclick="() => UpdateRole(user)">
                                Save Role
                            </button>

                        </div>

                    </article>
                }

            </div>
        }

    </section>

</div>

@code {

    private string message = "";
    private string search = "";
    private string selectedRole = "";
    private bool isLoading = true;

    private List<UserViewModel> users = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var role =
                await JS.InvokeAsync<string>("localStorage.getItem", "userRole");

            if (role != "SuperAdmin")
            {
                Nav.NavigateTo("/");
                return;
            }

            await LoadUsers();
            StateHasChanged();
        }
    }

    private async Task LoadUsers()
    {
        isLoading = true;

        var token =
            await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        using var req = new HttpRequestMessage(
            HttpMethod.Get,
            "https://localhost:7066/api/Auth/users");

        req.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var response = await Http.SendAsync(req);

        if (response.IsSuccessStatusCode)
        {
            var result =
                await response.Content.ReadFromJsonAsync<List<UserViewModel>>();

            users = result ?? new();

            foreach (var user in users)
                user.SelectedRole = user.Role;

            message = "";
        }
        else
        {
            message = "Failed to load users.";
        }

        isLoading = false;
    }

    private async Task UpdateRole(UserViewModel user)
    {
        var token =
            await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        using var req = new HttpRequestMessage(
            HttpMethod.Post,
            "https://localhost:7066/api/Auth/update-role");

        req.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        req.Content = JsonContent.Create(new
        {
            email = user.Email,
            role = user.SelectedRole
        });

        var response = await Http.SendAsync(req);

        if (response.IsSuccessStatusCode)
        {
            user.Role = user.SelectedRole;
            message = $"✅ Role updated for {user.FullName}";
        }
        else
        {
            message = $"❌ Failed updating {user.FullName}";
        }
    }

    private IEnumerable<UserViewModel> FilteredUsers =>
        users
        .Where(x =>
            (string.IsNullOrWhiteSpace(search)
            || x.FullName.Contains(search, StringComparison.OrdinalIgnoreCase)
            || x.Email.Contains(search, StringComparison.OrdinalIgnoreCase)
            || x.Role.Contains(search, StringComparison.OrdinalIgnoreCase))
            &&
            (string.IsNullOrWhiteSpace(selectedRole)
            || x.Role == selectedRole))
        .OrderBy(x => x.FullName);

    private string GetInitial(string value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "U"
            : value.Substring(0, 1).ToUpper();
    }

    private string GetRoleClass(string role)
    {
        return role switch
        {
            "SuperAdmin" => "super-role",
            "Admin" => "admin-role",
            _ => "user-role"
        };
    }

    public class UserViewModel
    {
        public int Id { get; set; }

        public string FullName { get; set; } = "";
        public string Email { get; set; } = "";

        public string Role { get; set; } = "";
        public string SelectedRole { get; set; } = "";

        public bool IsEmailVerified { get; set; }
    }
}