@page "/"

<PageTitle>EasySystems | Professional Online Stores</PageTitle>

<div class="home-page">

    <section class="home-hero">
        <div class="hero-content">
            <p class="eyebrow">EasySystems</p>

            <h1>We build professional online stores for growing businesses</h1>

            <p class="hero-text">
                Launch a modern e-commerce store with beautiful design, payment setup,
                mobile-friendly pages, product structure, and a clear process from request to launch.
            </p>

            <div class="hero-actions">
                <a href="/create-store" class="home-btn-primary">Start your store</a>
                <a href="/pricing" class="home-btn-secondary">View packages</a>
            </div>

            <div class="trust-row">
                <span>✓ Built in Sweden</span>
                <span>✓ Mobile first</span>
                <span>✓ Email updates</span>
                <span>✓ Admin tracking</span>
            </div>
        </div>

        <div class="hero-card premium-preview">
            <div class="store-preview-top">
                <span></span>
                <span></span>
                <span></span>
            </div>

            <div class="preview-badge">Live Store Preview</div>
            <div class="preview-product large"></div>

            <div class="preview-grid">
                <div></div>
                <div></div>
                <div></div>
            </div>

            <div class="preview-line"></div>
            <div class="preview-line short"></div>
        </div>
    </section>

    <section class="home-services">
        <div class="section-heading">
            <p class="eyebrow">What we do</p>
            <h2>Everything your business needs to sell online</h2>
        </div>

        <div class="service-grid">
            <div class="service-card">
                <h3>Online store development</h3>
                <p>Professional e-commerce stores where customers can explore products and send orders easily.</p>
            </div>

            <div class="service-card">
                <h3>Payment & checkout setup</h3>
                <p>We prepare your store for smooth checkout and online payment options.</p>
            </div>

            <div class="service-card">
                <h3>Premium design</h3>
                <p>A clean, modern design that matches your brand and builds customer trust.</p>
            </div>

            <div class="service-card">
                <h3>Product structure</h3>
                <p>Categories, product pages, descriptions, and store layout built in a clear way.</p>
            </div>

            <div class="service-card">
                <h3>Multilingual stores</h3>
                <p>Swedish, Arabic, English, or the language mix your customers need.</p>
            </div>

            <div class="service-card">
                <h3>Launch support</h3>
                <p>We guide you after delivery so your store stays stable, clean, and ready for customers.</p>
            </div>
        </div>
    </section>

    <section class="why-section">
        <div class="section-heading">
            <p class="eyebrow">Why EasySystems</p>
            <h2>Not just a website. A complete launch system.</h2>
        </div>

        <div class="why-grid">
            <div>
                <span>01</span>
                <h3>Clear request process</h3>
                <p>Your customer answers structured questions, so every project starts with the right information.</p>
            </div>

            <div>
                <span>02</span>
                <h3>Project tracking</h3>
                <p>Customers can log in, follow status updates, and receive emails when progress changes.</p>
            </div>

            <div>
                <span>03</span>
                <h3>Admin control</h3>
                <p>You manage requests, customers, project statuses, and details from one admin dashboard.</p>
            </div>
        </div>
    </section>

    <section class="home-process">
        <div class="section-heading">
            <p class="eyebrow">How it works</p>
            <h2>From idea to online store</h2>
        </div>

        <div class="process-grid">
            <div class="process-step">
                <span>01</span>
                <h3>Choose package</h3>
                <p>Select the package that fits your business and budget.</p>
            </div>

            <div class="process-step">
                <span>02</span>
                <h3>Answer questions</h3>
                <p>Tell us about products, design, payment, shipping, languages, and launch goals.</p>
            </div>

            <div class="process-step">
                <span>03</span>
                <h3>We review</h3>
                <p>We check the request and update the project status in your dashboard.</p>
            </div>

            <div class="process-step">
                <span>04</span>
                <h3>Launch</h3>
                <p>Your online store becomes ready for real customers.</p>
            </div>
        </div>
    </section>

    <section class="pricing-preview">
        <div class="section-heading">
            <p class="eyebrow">Packages</p>
            <h2>Start small or build a complete store</h2>
        </div>

        <div class="pricing-preview-grid">
            <div class="pricing-mini-card">
                <h3>Starter</h3>
                <p class="mini-price">4,900 kr</p>
                <p>For small businesses starting online.</p>
            </div>

            <div class="pricing-mini-card featured-mini">
                <span>Popular</span>
                <h3>Business</h3>
                <p class="mini-price">9,900 kr</p>
                <p>For serious stores that need payment, design, and structure.</p>
            </div>

            <div class="pricing-mini-card">
                <h3>Premium</h3>
                <p class="mini-price">19,900 kr</p>
                <p>For businesses that want a complete professional solution.</p>
            </div>
        </div>

        <div class="pricing-action">
            <a href="/create-store" class="home-btn-primary">Choose your package</a>
        </div>
    </section>

    <section class="home-cta">
        <h2>Ready to build your online store?</h2>
        <p>Submit your request, choose your package, and we’ll contact you with the next step.</p>
        <a href="/create-store" class="home-btn-primary">Start now</a>
    </section>

</div>