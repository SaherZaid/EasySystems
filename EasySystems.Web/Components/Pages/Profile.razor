@page "/profile"
@rendermode InteractiveServer
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Profile</PageTitle>

<div class="profile-page">

    <section class="profile-card">

        <div class="profile-top">
            <div class="avatar-circle">
                @FirstLetter
            </div>

            <div>
                <p class="eyebrow">My Account</p>
                <h1>@FullName</h1>
                <p>@model.Email</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="admin-message">@message</div>
        }

        @if (isLoading)
        {
            <div class="admin-message">Loading profile...</div>
        }
        else
        {
            <div class="profile-grid">

                <div class="profile-box">
                    <span>First Name</span>
                    <input @bind="model.FirstName" />
                </div>

                <div class="profile-box">
                    <span>Last Name</span>
                    <input @bind="model.LastName" />
                </div>

                <div class="profile-box">
                    <span>Email</span>
                    <input @bind="model.Email" />
                </div>

                <div class="profile-box">
                    <span>Phone</span>
                    <input @bind="model.PhoneNumber" />
                </div>

                <div class="profile-box">
                    <span>Role</span>
                    <strong>@model.Role</strong>
                </div>

                <div class="profile-box">
                    <span>Status</span>
                    <strong>Active</strong>
                </div>

            </div>

            <button class="auth-btn" @onclick="SaveProfile" disabled="@isSaving">
                @(isSaving ? "Saving..." : "Save Changes")
            </button>
        }

    </section>

</div>

@code {
    private string message = "";
    private bool isLoading = true;
    private bool isSaving = false;

    private ProfileModel model = new();

    private string FullName =>
        string.IsNullOrWhiteSpace($"{model.FirstName} {model.LastName}".Trim())
            ? "User Account"
            : $"{model.FirstName} {model.LastName}".Trim();

    private string FirstLetter =>
        string.IsNullOrWhiteSpace(model.FirstName)
            ? "U"
            : model.FirstName.Substring(0, 1).ToUpper();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadProfile();
            StateHasChanged();
        }
    }

    private async Task LoadProfile()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        if (string.IsNullOrWhiteSpace(token))
        {
            Nav.NavigateTo("/login");
            return;
        }

        using var request = new HttpRequestMessage(
            HttpMethod.Get,
            "https://localhost:7066/api/Profile/me");

        request.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var response = await Http.SendAsync(request);

        if (!response.IsSuccessStatusCode)
        {
            message = "Could not load profile.";
            isLoading = false;
            return;
        }

        var result = await response.Content.ReadFromJsonAsync<ProfileModel>();

        if (result is not null)
            model = result;

        isLoading = false;
    }

    private async Task SaveProfile()
    {
        message = "";
        isSaving = true;

        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        using var request = new HttpRequestMessage(
            HttpMethod.Put,
            "https://localhost:7066/api/Profile/update");

        request.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        request.Content = JsonContent.Create(new
        {
            model.FirstName,
            model.LastName,
            model.Email,
            model.PhoneNumber
        });

        var response = await Http.SendAsync(request);

        isSaving = false;

        if (response.IsSuccessStatusCode)
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "userEmail", model.Email);
            await JS.InvokeVoidAsync("localStorage.setItem", "firstName", model.FirstName);
            await JS.InvokeVoidAsync("localStorage.setItem", "lastName", model.LastName);

            message = "Profile updated successfully.";
        }
        else
        {
            message = "Could not update profile.";
        }
    }

    public class ProfileModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string PhoneNumber { get; set; } = "";
        public string Role { get; set; } = "";
    }
}