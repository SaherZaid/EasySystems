@page "/login"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject EasySystems.Web.Services.AuthStateService Auth

<PageTitle>Login</PageTitle>

<div class="auth-page">

    <section class="auth-card">

        <div class="auth-left">
            <p class="eyebrow">EasySystems</p>
            <h1>Secure login</h1>
            <p>
                Access your dashboard using a one-time secure email token.
                Fast, simple, and passwordless.
            </p>

            <ul>
                <li>✓ Passwordless access</li>
                <li>✓ Secure verification token</li>
                <li>✓ Instant dashboard access</li>
                <li>✓ Admin role support</li>
            </ul>
        </div>

        <div class="auth-right">

            <h2>Login</h2>

            @if (!codeSent)
            {
                <input @bind="email" placeholder="Email address" />

                <button class="auth-btn" @onclick="SendCode">
                    Continue
                </button>
            }
            else
            {
                <div class="success-badge">
                    Token sent to: @email
                </div>

                @if (!string.IsNullOrWhiteSpace(devCode))
                {
                    <div class="dev-code-box">
                        Test code: <strong>@devCode</strong>
                    </div>
                }

                <input @bind="code" placeholder="Enter verification code" />

                <button class="auth-btn" @onclick="LoginWithCode">
                    Login now
                </button>

                <button class="auth-btn-secondary"
                        @onclick="ResendCode"
                        disabled="@waitingResend">
                    @(waitingResend
                        ? $"Resend in {secondsLeft}s"
                        : "Resend code")
                </button>
            }

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <p class="auth-message">@message</p>
            }

            <p class="auth-link">
                No account?
                <a href="/register">Create account</a>
            </p>

        </div>

    </section>

</div>

@code {
    private string email = "";
    private string code = "";
    private string devCode = "";
    private string message = "";

    private bool codeSent;
    private bool waitingResend;
    private int secondsLeft = 30;

    private async Task SendCode()
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            message = "Please enter your email.";
            return;
        }

        var response = await Http.PostAsJsonAsync(
            "https://localhost:7066/api/Auth/send-code",
            email);

        if (response.IsSuccessStatusCode)
        {
            var result =
                await response.Content.ReadFromJsonAsync<SendCodeResponse>();

            devCode = result?.Code ?? "";
            code = devCode;

            codeSent = true;
            message = "Verification code was sent to your mail.";

            await StartResendTimer();
        }
        else
        {
            message = await response.Content.ReadAsStringAsync();
        }
    }

    private async Task LoginWithCode()
    {
        var response = await Http.PostAsJsonAsync(
            "https://localhost:7066/api/Auth/verify-code",
            new
            {
                Email = email,
                Code = code
            });

        if (response.IsSuccessStatusCode)
        {
            var result =
                await response.Content.ReadFromJsonAsync<LoginResponse>();

            if (result is not null)
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "authToken", result.Token);
                await JS.InvokeVoidAsync("localStorage.setItem", "userRole", result.Role);
                await JS.InvokeVoidAsync("localStorage.setItem", "userEmail", result.Email);

                Auth.SetUser(true, result.Role);
            }

            message = "Login successful.";

            await Task.Delay(500);
            Nav.NavigateTo("/dashboard");
        }
        else
        {
            message = "Invalid or expired token.";
        }
    }

    private async Task ResendCode()
    {
        await SendCode();
    }

    private async Task StartResendTimer()
    {
        waitingResend = true;
        secondsLeft = 30;

        while (secondsLeft > 0)
        {
            await Task.Delay(1000);
            secondsLeft--;
            StateHasChanged();
        }

        waitingResend = false;
        StateHasChanged();
    }

    public class SendCodeResponse
    {
        public string Code { get; set; } = "";
    }

    public class LoginResponse
    {
        public string Email { get; set; } = "";
        public string Role { get; set; } = "";
        public string Token { get; set; } = "";
    }
}