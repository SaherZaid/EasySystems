@rendermode InteractiveServer
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject EasySystems.Web.Services.AuthStateService Auth
@implements IDisposable

@if (!loaded)
{
    <span class="login-link">...</span>
}
else if (!Auth.IsLoggedIn)
{
    <NavLink href="/login" class="login-link">
        Login
    </NavLink>
}
else
{
    <div class="user-menu">

        <button class="user-menu-button" @onclick="ToggleMenu">
            <span class="user-avatar">@firstLetter</span>
            <span>@displayName</span>
            <span>▾</span>
        </button>

        @if (menuOpen)
        {
            <div class="user-dropdown">

                <NavLink href="/dashboard" @onclick="CloseMenu">
                    My Projects
                </NavLink>

                <NavLink href="/profile" @onclick="CloseMenu">
                    Profile
                </NavLink>

                @if (IsAdminOrSuperAdmin)
                {
                    <NavLink href="/admin/requests" @onclick="CloseMenu">
                        Admin Panel
                    </NavLink>

                    <NavLink href="/admin/leads" @onclick="CloseMenu">
                        Inbox
                    </NavLink>
                }

                @if (IsSuperAdmin)
                {
                    <NavLink href="/admin/users" @onclick="CloseMenu">
                        Users & Roles
                    </NavLink>
                }

                <button @onclick="Logout">
                    Logout
                </button>

            </div>
        }

    </div>
}

@code {

    bool loaded;
    bool menuOpen;

    string displayName = "Account";
    string firstLetter = "U";
    string role = "";

    bool IsAdminOrSuperAdmin =>
        role == "Admin" || role == "SuperAdmin";

    bool IsSuperAdmin =>
        role == "SuperAdmin";

    protected override void OnInitialized()
    {
        Auth.OnChange += RefreshUi;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadUser();
            loaded = true;
            StateHasChanged();
        }
    }

    async Task LoadUser()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        role = await JS.InvokeAsync<string>("localStorage.getItem", "userRole") ?? "";

        var email = await JS.InvokeAsync<string>("localStorage.getItem", "userEmail");

        var firstName = await JS.InvokeAsync<string>("localStorage.getItem", "firstName");

        Auth.SetUser(!string.IsNullOrWhiteSpace(token), role);

        displayName =
            !string.IsNullOrWhiteSpace(firstName)
            ? firstName
            : !string.IsNullOrWhiteSpace(email)
                ? email.Split('@')[0]
                : "Account";

        firstLetter = displayName.Substring(0, 1).ToUpper();
    }

    void ToggleMenu()
    {
        menuOpen = !menuOpen;
    }

    void CloseMenu()
    {
        menuOpen = false;
    }

    void RefreshUi()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadUser();
            StateHasChanged();
        });
    }

    async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "authToken");
        await JS.InvokeVoidAsync("localStorage.removeItem", "userRole");
        await JS.InvokeVoidAsync("localStorage.removeItem", "userEmail");
        await JS.InvokeVoidAsync("localStorage.removeItem", "firstName");
        await JS.InvokeVoidAsync("localStorage.removeItem", "lastName");

        Auth.Logout();

        menuOpen = false;

        Nav.NavigateTo("/", true);
    }

    public void Dispose()
    {
        Auth.OnChange -= RefreshUi;
    }
}