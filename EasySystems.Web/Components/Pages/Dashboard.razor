@page "/dashboard"
@rendermode InteractiveServer
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Dashboard</PageTitle>

<div class="customer-dashboard">

    <section class="dashboard-hero">
        <div>
            <p class="eyebrow">Customer Dashboard</p>
            <h1>Your store requests</h1>
            <p>Track your online store requests, package choice, and current progress.</p>
        </div>

        <a href="/create-store" class="dashboard-cta">Create new request</a>
    </section>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="admin-message">@message</div>
    }

    <section class="dashboard-stats">
        <div>
            <span>@requests.Count</span>
            <p>Total requests</p>
        </div>

        <div>
            <span>@requests.Count(x => x.Status == "Pending")</span>
            <p>Pending</p>
        </div>

        <div>
            <span>@requests.Count(x => x.Status == "In Progress")</span>
            <p>In Progress</p>
        </div>

        <div>
            <span>@requests.Count(x => x.Status == "Completed")</span>
            <p>Completed</p>
        </div>
    </section>

    <section class="customer-request-list">
        @if (!requests.Any())
        {
            <div class="empty-dashboard">
                <h2>No requests yet</h2>
                <p>Create your first online store request and we’ll review it.</p>
                <a href="/create-store" class="dashboard-cta">Start now</a>
            </div>
        }
        else
        {
            @foreach (var request in requests)
            {
                <article class="customer-request-card">
                    <div class="customer-request-header">
                        <div>
                            <span class="status-pill @GetStatusClass(request.Status)">
                                @request.Status
                            </span>

                            <h2>@request.StoreName</h2>
                            <p>@request.BusinessType</p>
                        </div>

                        <div class="package-badge">
                            @request.PackageName
                        </div>
                    </div>

                    <div class="customer-request-footer">
                        <span>Submitted: @request.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                        <span>Request ID: #@request.Id</span>
                    </div>
                </article>
            }
        }
    </section>
</div>

@code {
    private string message = "";
    private List<MyStoreRequestViewModel> requests = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadMyRequests();
            StateHasChanged();
        }
    }

    private async Task LoadMyRequests()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        if (string.IsNullOrWhiteSpace(token))
        {
            message = "Please login first.";
            return;
        }

        using var httpRequest = new HttpRequestMessage(
            HttpMethod.Get,
            "https://localhost:7066/api/StoreRequests/my");

        httpRequest.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var response = await Http.SendAsync(httpRequest);

        if (!response.IsSuccessStatusCode)
        {
            message = $"Could not load your requests. Status: {(int)response.StatusCode}";
            return;
        }

        var result = await response.Content.ReadFromJsonAsync<List<MyStoreRequestViewModel>>();

        requests = result ?? new();
        message = "";
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Pending" => "status-pending",
            "In Review" => "status-review",
            "Approved" => "status-approved",
            "In Progress" => "status-progress",
            "Completed" => "status-completed",
            "Rejected" => "status-rejected",
            _ => "status-pending"
        };
    }

    public class MyStoreRequestViewModel
    {
        public int Id { get; set; }
        public string StoreName { get; set; } = "";
        public string BusinessType { get; set; } = "";
        public string PackageName { get; set; } = "";
        public string Status { get; set; } = "";
        public DateTime CreatedAtUtc { get; set; }
    }
}