@page "/admin/requests"
@rendermode InteractiveServer
@using System.Net.Http.Headers
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Admin CRM | EasySystems</PageTitle>

<div class="admin-saas">

    <aside class="admin-sidebar">
        <div class="admin-logo">
            <span>E</span>
            <strong>EasySystems</strong>
        </div>

        <nav>
            <NavLink href="/admin/requests" class="active">Requests CRM</NavLink>
            <NavLink href="/admin/users">Users & Roles</NavLink>
            <a>Customers</a>
            <a>Analytics</a>
            <a>Settings</a>
        </nav>
    </aside>

    <main class="admin-main">

        <header class="admin-topbar">
            <div>
                <p class="eyebrow">EasySystems CRM</p>
                <h1>Project Requests</h1>
            </div>

            <button class="admin-refresh" @onclick="LoadRequests">
                Refresh
            </button>
        </header>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="admin-message">@message</div>
        }

        <section class="saas-stats revenue-grid">

            <div>
                <span>@requests.Count</span>
                <p>Total Requests</p>
            </div>

            <div>
                <span>@PendingCount</span>
                <p>Pending</p>
            </div>

            <div>
                <span>@CompletedCount</span>
                <p>Completed</p>
            </div>

            <div>
                <span>@TotalRevenue.ToString("N0") kr</span>
                <p>Total Revenue</p>
            </div>

            <div>
                <span>@PendingRevenue.ToString("N0") kr</span>
                <p>Open Pipeline</p>
            </div>

            <div>
                <span>@MonthlyRevenue.ToString("N0") kr</span>
                <p>This Month</p>
            </div>

        </section>

        <section class="chart-panel">

            <div class="panel-header">
                <div>
                    <h2>Revenue Analytics</h2>
                    <p class="panel-subtitle">Completed projects income by month</p>
                </div>
            </div>

            <div class="revenue-chart">

                @foreach (var item in MonthlyChartData)
                {
                    <div class="chart-col">

                        <div class="chart-bar-wrap">
                            <div class="chart-bar"
                                 style="height:@item.Height%">
                            </div>
                        </div>

                        <strong>@item.Month</strong>
                        <span>@item.Amount.ToString("N0")</span>

                    </div>
                }

            </div>

        </section>


        <section class="saas-panel">

            <div class="panel-header">
                <div>
                    <h2>Requests Pipeline</h2>
                    <p class="panel-subtitle">Manage leads, project status, and customer follow-up.</p>
                </div>

                <div class="panel-tools">
                    <input @bind="search" @bind:event="oninput" placeholder="Search name, email, store, phone..." />

                    <select @bind="selectedStatus">
                        <option value="">All statuses</option>
                        @foreach (var status in statuses)
                        {
                            <option value="@status">@status</option>
                        }
                    </select>

                    <select @bind="selectedSort">
                        <option value="Newest">Newest</option>
                        <option value="Oldest">Oldest</option>
                        <option value="Premium">Premium first</option>
                        <option value="Pending">Pending first</option>
                    </select>
                </div>
            </div>

            <div class="request-table">

                <div class="table-head crm-table-head">
                    <span>Customer</span>
                    <span>Project</span>
                    <span>Package</span>
                    <span>Priority</span>
                    <span>Status</span>
                    <span>Date</span>
                    <span>Action</span>
                </div>

                @if (isLoading)
                {
                    <div class="admin-message">Loading requests...</div>
                }
                else if (!FilteredRequests.Any())
                {
                    <div class="admin-message">No requests found.</div>
                }
                else
                {
                    @foreach (var request in FilteredRequests)
                    {
                        <div class="table-row crm-table-row">
                            <div class="customer-cell">
                                <div class="customer-avatar">
                                    @GetInitial(request.CustomerFullName)
                                </div>

                                <div>
                                    <strong>@request.CustomerFullName</strong>
                                    <p>@request.CustomerEmail</p>
                                    <p>@request.CustomerPhoneNumber</p>
                                </div>
                            </div>

                            <div>
                                <strong>@request.StoreName</strong>
                                <p>@request.BusinessType</p>
                            </div>

                            <div>
                                <span class="package-chip">@request.PackageName</span>
                            </div>

                            <div>
                                <select class="mini-select" @bind="request.Priority">
                                    <option>Low</option>
                                    <option>Medium</option>
                                    <option>High</option>
                                    <option>Hot Lead</option>
                                </select>
                            </div>

                            <div>
                                <span class="status-pill @GetStatusClass(request.Status)">
                                    @request.Status
                                </span>
                            </div>

                            <div>
                                @request.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd")
                            </div>

                            <div class="row-actions">

                                <button class="view-btn"
                                        @onclick="() => OpenDetails(request)">
                                    View
                                </button>

                                <button class="invoice-btn"
                                        @onclick="() => DownloadInvoice(request.Id)">
                                    Invoice
                                </button>

                            </div>
                        </div>
                    }
                }

            </div>

        </section>

    </main>

    @if (selectedRequest is not null)
    {
        <div class="details-backdrop" @onclick="CloseDetails"></div>

        <aside class="details-drawer">

            @if (!string.IsNullOrWhiteSpace(drawerMessage))
            {
                <div class="drawer-success">
                    @drawerMessage
                </div>
            }

            <div class="drawer-header">
                <div>
                    <p class="eyebrow">CRM Details</p>
                    <h2>@selectedRequest.StoreName</h2>
                </div>

                <button @onclick="CloseDetails">×</button>
            </div>

            <div class="drawer-section">
                <h3>Customer</h3>

                <div class="drawer-grid">
                    <div><span>Name</span><strong>@selectedRequest.CustomerFullName</strong></div>
                    <div><span>Email</span><strong>@selectedRequest.CustomerEmail</strong></div>
                    <div><span>Phone</span><strong>@selectedRequest.CustomerPhoneNumber</strong></div>
                    <div><span>Package</span><strong>@selectedRequest.PackageName</strong></div>
                </div>

                <div class="crm-contact-actions">
                    <a href="mailto:@selectedRequest.CustomerEmail">Email Client</a>
                    <a href="tel:@selectedRequest.CustomerPhoneNumber">Call Client</a>
                </div>
            </div>

            <div class="drawer-section">
                <h3>Project</h3>

                <div class="drawer-grid">
                    <div><span>Store</span><strong>@selectedRequest.StoreName</strong></div>
                    <div><span>Business</span><strong>@selectedRequest.BusinessType</strong></div>
                    <div><span>Created</span><strong>@selectedRequest.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</strong></div>
                    <div><span>Status</span><strong>@selectedRequest.Status</strong></div>
                </div>
            </div>

            <div class="drawer-section">
                <h3>CRM Controls</h3>

                <div class="drawer-grid">
                    <div>
                        <span>Priority</span>

                        <select class="drawer-input" @bind="selectedRequest.Priority">
                            <option>Low</option>
                            <option>Medium</option>
                            <option>High</option>
                            <option>Hot Lead</option>
                        </select>

                        <div class="save-row">
                            <button class="drawer-save-note"
                                    @onclick="SavePriority">
                                Save Priority
                            </button>

                            @if (prioritySaved)
                            {
                                <span class="mini-success">Saved ✔</span>
                            }
                        </div>
                    </div>

                    <div>
                        <span>Assigned To</span>
                        <select class="drawer-input"
                                @bind="selectedRequest.AssignedTo">

                            <option value="">Select user</option>

                            @foreach (var admin in admins)
                            {
                                <option value="@admin.Email">
                                    @admin.FullName (@admin.Role)
                                </option>
                            }

                        </select>

                        <div class="save-row">
                            <button class="drawer-save-note"
                                    @onclick="AssignTask">
                                Assign
                            </button>

                            @if (assignSaved)
                            {
                                <span class="mini-success">Assigned ✔</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="drawer-section">
                <h3>Client Notes</h3>
                <p class="drawer-notes">@selectedRequest.Notes</p>
            </div>

            <div class="drawer-section">
                <h3>Internal Notes</h3>

                <textarea class="drawer-textarea"
                          @bind="selectedRequest.InternalNote"
                          placeholder="Write internal admin notes here..."></textarea>

                <div class="save-row">
                    <button class="drawer-save-note" @onclick="SaveInternalNote">
                        Save Note
                    </button>

                    @if (noteSaved)
                    {
                        <span class="mini-success">Saved ✔</span>
                    }
                </div>
            </div>

            @if (selectedRequest.Answers.Any())
            {
                <div class="drawer-section">
                    <h3>Client Answers</h3>

                    <div class="drawer-answers">
                        @foreach (var answer in selectedRequest.Answers)
                        {
                            <div>
                                <span>@answer.Question</span>
                                <strong>@answer.Answer</strong>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="drawer-section">
                <h3>Update Status</h3>

                <div class="drawer-status-row">
                    <select @bind="selectedRequest.SelectedStatus">
                        @foreach (var status in statuses)
                        {
                            <option value="@status">@status</option>
                        }
                    </select>

                    <div class="save-row">
                        <button @onclick="() => UpdateStatus(selectedRequest)">
                            Save Status
                        </button>

                        @if (statusSaved)
                        {
                            <span class="mini-success">Updated ✔</span>
                        }
                    </div>
                </div>
            </div>

        </aside>
    }

</div>

@code {
    private string message = "";
    private string drawerMessage = "";
    private string search = "";
    private string selectedStatus = "";
    private string selectedSort = "Newest";
    private bool isLoading = true;

    bool prioritySaved = false;
    bool assignSaved = false;
    bool noteSaved = false;
    bool statusSaved = false;

    private StoreRequestViewModel? selectedRequest;
    private List<StoreRequestViewModel> requests = new();

    private List<AdminUserVm> admins = new();

    public class AdminUserVm
    {
        public string FullName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Role { get; set; } = "";
    }

    private List<ChartItem> MonthlyChartData =>
    BuildChart();

    private List<ChartItem> BuildChart()
    {
        var months = new[]
        {
        "Jan","Feb","Mar","Apr","May","Jun",
        "Jul","Aug","Sep","Oct","Nov","Dec"
    };

        var data = new List<ChartItem>();

        for (int i = 1; i <= 12; i++)
        {
            var amount = requests
                .Where(x =>
                    x.Status == "Completed" &&
                    x.CreatedAtUtc.Year == DateTime.UtcNow.Year &&
                    x.CreatedAtUtc.Month == i)
                .Sum(x => GetPackagePrice(x.PackageName));

            data.Add(new ChartItem
                {
                    Month = months[i - 1],
                    Amount = amount
                });
        }

        var max = data.Max(x => x.Amount);

        foreach (var item in data)
        {
            item.Height = max == 0
                ? 8
                : Math.Max(8, (item.Amount / max) * 100);
        }

        return data;
    }

    public class ChartItem
    {
        public string Month { get; set; } = "";
        public decimal Amount { get; set; }
        public decimal Height { get; set; }
    }


    private int PendingCount =>
    requests.Count(x => x.Status == "Pending");

    private int CompletedCount =>
        requests.Count(x => x.Status == "Completed");

    private decimal TotalRevenue =>
        requests
            .Where(x => x.Status == "Completed")
            .Sum(x => GetPackagePrice(x.PackageName));


    private decimal PendingRevenue =>
    requests
        .Where(x =>
            x.Status == "Pending" ||
            x.Status == "In Review" ||
            x.Status == "Approved" ||
            x.Status == "In Progress")
        .Sum(x => GetPackagePrice(x.PackageName));

    private decimal MonthlyRevenue =>
        requests
            .Where(x =>
                x.Status == "Completed" &&
                x.CreatedAtUtc.Month == DateTime.UtcNow.Month &&
                x.CreatedAtUtc.Year == DateTime.UtcNow.Year)
            .Sum(x => GetPackagePrice(x.PackageName));

    private decimal GetPackagePrice(string package)
    {
        return package switch
        {
            "Starter" => 4900,
            "Business" => 9900,
            "Premium" => 19900,
            _ => 0
        };
    }

    private readonly string[] statuses =
    {
        "Pending",
        "In Review",
        "Approved",
        "In Progress",
        "Completed",
        "Rejected"
    };

    private IEnumerable<StoreRequestViewModel> FilteredRequests
    {
        get
        {
            var query = requests.Where(x =>
                (string.IsNullOrWhiteSpace(search)
                 || x.CustomerFullName.Contains(search, StringComparison.OrdinalIgnoreCase)
                 || x.CustomerEmail.Contains(search, StringComparison.OrdinalIgnoreCase)
                 || x.CustomerPhoneNumber.Contains(search, StringComparison.OrdinalIgnoreCase)
                 || x.StoreName.Contains(search, StringComparison.OrdinalIgnoreCase)
                 || x.Id.ToString().Contains(search))
                &&
                (string.IsNullOrWhiteSpace(selectedStatus)
                 || x.Status == selectedStatus));

            return selectedSort switch
            {
                "Oldest" => query.OrderBy(x => x.CreatedAtUtc),
                "Premium" => query.OrderByDescending(x => x.PackageName == "Premium")
                                  .ThenByDescending(x => x.CreatedAtUtc),
                "Pending" => query.OrderByDescending(x => x.Status == "Pending")
                                  .ThenByDescending(x => x.CreatedAtUtc),
                _ => query.OrderByDescending(x => x.CreatedAtUtc)
            };
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var role = await JS.InvokeAsync<string>("localStorage.getItem", "userRole");

            if (role != "Admin" && role != "SuperAdmin")
            {
                Nav.NavigateTo("/");
                return;
            }

            await LoadAdmins();
            await LoadRequests();
            StateHasChanged();
        }
    }

    private async Task SavePriority()
    {
        if (selectedRequest is null) return;

        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        using var req = new HttpRequestMessage(
            HttpMethod.Put,
            $"https://localhost:7066/api/StoreRequests/{selectedRequest.Id}/crm");

        req.Headers.Authorization =
            new AuthenticationHeaderValue("Bearer", token);

        req.Content = JsonContent.Create(new
        {
            priority = selectedRequest.Priority,
            assignedTo = selectedRequest.AssignedTo,
            internalNote = selectedRequest.InternalNote
        });

        var response = await Http.SendAsync(req);

        if (response.IsSuccessStatusCode)
        {
            prioritySaved = true;
            StateHasChanged();

            await Task.Delay(2000);

            prioritySaved = false;
            StateHasChanged();
        }
    }

    private async Task LoadAdmins()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        using var req = new HttpRequestMessage(
            HttpMethod.Get,
            "https://localhost:7066/api/Auth/users");

        req.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var response = await Http.SendAsync(req);

        if (!response.IsSuccessStatusCode)
            return;

        var users =
            await response.Content.ReadFromJsonAsync<List<AdminUserVm>>();

        admins = users?
            .Where(x => x.Role == "Admin" || x.Role == "SuperAdmin")
            .ToList() ?? new();
    }

    private async Task LoadRequests()
    {
        isLoading = true;

        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        using var httpRequest = new HttpRequestMessage(
            HttpMethod.Get,
            "https://localhost:7066/api/StoreRequests");

        httpRequest.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var response = await Http.SendAsync(httpRequest);

        if (!response.IsSuccessStatusCode)
        {
            message = $"Could not load requests. Status: {(int)response.StatusCode}";
            isLoading = false;
            return;
        }

        var result = await response.Content.ReadFromJsonAsync<List<StoreRequestViewModel>>();

        requests = result ?? new();

        foreach (var item in requests)
        {
            item.SelectedStatus = item.Status;

            if (string.IsNullOrWhiteSpace(item.Priority))
                item.Priority = item.PackageName == "Premium" ? "Hot Lead" : "Medium";
        }

        message = "";
        isLoading = false;
    }

    private void OpenDetails(StoreRequestViewModel request)
    {
        selectedRequest = request;
        drawerMessage = "";
    }

    private void CloseDetails()
    {
        selectedRequest = null;
    }

    private async Task SaveInternalNote()
    {
        if (selectedRequest is null) return;

        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        using var req = new HttpRequestMessage(
            HttpMethod.Put,
            $"https://localhost:7066/api/StoreRequests/{selectedRequest.Id}/crm");

        req.Headers.Authorization =
            new AuthenticationHeaderValue("Bearer", token);

        req.Content = JsonContent.Create(new
        {
            priority = selectedRequest.Priority,
            assignedTo = selectedRequest.AssignedTo,
            internalNote = selectedRequest.InternalNote
        });

        var response = await Http.SendAsync(req);

        if (response.IsSuccessStatusCode)
        {
            noteSaved = true;
            StateHasChanged();

            await Task.Delay(2000);

            noteSaved = false;
            StateHasChanged();
        }
    }

    private async Task UpdateStatus(StoreRequestViewModel request)
    {
        drawerMessage = "Updating status...";

        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        using var httpRequest = new HttpRequestMessage(
            HttpMethod.Put,
            $"https://localhost:7066/api/StoreRequests/{request.Id}/status");

        httpRequest.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        httpRequest.Content = JsonContent.Create(new
        {
            status = request.SelectedStatus
        });

        var response = await Http.SendAsync(httpRequest);

        if (response.IsSuccessStatusCode)
        {
            request.Status = request.SelectedStatus;

            statusSaved = true;
            StateHasChanged();

            await Task.Delay(2000);

            statusSaved = false;
            StateHasChanged();
        }
        else
        {
            drawerMessage = "❌ Failed to update status.";
        }

        StateHasChanged();
    }


    private async Task AssignTask()
    {
        if (selectedRequest is null)
            return;

        if (string.IsNullOrWhiteSpace(selectedRequest.AssignedTo))
        {
            message = "Please select admin.";
            return;
        }

        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        using var req = new HttpRequestMessage(
            HttpMethod.Post,
            "https://localhost:7066/api/Auth/assign-task");

        req.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        req.Content = JsonContent.Create(new
        {
            email = selectedRequest.AssignedTo,
            project = selectedRequest.StoreName,
            customer = selectedRequest.CustomerFullName
        });

        var response = await Http.SendAsync(req);

        if (response.IsSuccessStatusCode)
        {
            assignSaved = true;
            StateHasChanged();

            await Task.Delay(2000);

            assignSaved = false;
            StateHasChanged();
        }
        else
        {
            message = "Could not assign task.";
        }
    }
    async Task DownloadInvoice(int requestId)
    {
        var token = await JS.InvokeAsync<string>(
            "localStorage.getItem",
            "authToken");

        using var req = new HttpRequestMessage(
            HttpMethod.Get,
            $"https://localhost:7066/api/Invoices/request/{requestId}");

        req.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue(
                "Bearer",
                token);

        var response = await Http.SendAsync(req);

        if (!response.IsSuccessStatusCode)
        {
            message = "Could not generate invoice.";
            return;
        }

        var bytes = await response.Content.ReadAsByteArrayAsync();

        var base64 = Convert.ToBase64String(bytes);

        await JS.InvokeVoidAsync(
            "downloadFileFromBytes",
            $"invoice-{requestId}.pdf",
            base64);
    }


    private string GetInitial(string value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "?"
            : value.Substring(0, 1).ToUpper();
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Pending" => "status-pending",
            "In Review" => "status-review",
            "Approved" => "status-approved",
            "In Progress" => "status-progress",
            "Completed" => "status-completed",
            "Rejected" => "status-rejected",
            _ => "status-pending"
        };
    }

    public class StoreRequestViewModel
    {
        public int Id { get; set; }

        public string CustomerFullName { get; set; } = "";
        public string CustomerEmail { get; set; } = "";
        public string CustomerPhoneNumber { get; set; } = "";

        public string StoreName { get; set; } = "";
        public string BusinessType { get; set; } = "";
        public string PackageName { get; set; } = "";
        public string Notes { get; set; } = "";

        public string Status { get; set; } = "";
        public string SelectedStatus { get; set; } = "";

        public string Priority { get; set; } = "Medium";
        public string AssignedTo { get; set; } = "";
        public string InternalNote { get; set; } = "";

        public DateTime CreatedAtUtc { get; set; }

        public List<QuestionAnswerViewModel> Answers { get; set; } = new();
    }

    public class QuestionAnswerViewModel
    {
        public string Question { get; set; } = "";
        public string Answer { get; set; } = "";
    }
}