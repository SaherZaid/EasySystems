@page "/login"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Login</PageTitle>

<h1>Login</h1>

<div class="register-box">
    <input @bind="email" placeholder="Email" />

    <button @onclick="SendCode">Send login code</button>

    @if (!string.IsNullOrWhiteSpace(devCode))
    {
        <p style="font-weight:bold; color:#2563eb;">
            Test code: @devCode
        </p>
    }

    <input @bind="code" placeholder="Login code" />

    <button @onclick="LoginWithCode">Login</button>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p>@message</p>
    }
</div>

@code {
    private string email = "";
    private string code = "";
    private string message = "";
    private string devCode = "";

    private async Task SendCode()
    {
        var response = await Http.PostAsJsonAsync(
            "https://localhost:7066/api/Auth/send-code",
            email);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<SendCodeResponse>();

            devCode = result?.Code ?? "";
            code = devCode;

            message = "Login code created.";
        }
        else
        {
            message = "Could not send login code.";
        }
    }

    private async Task LoginWithCode()
    {
        var response = await Http.PostAsJsonAsync(
            "https://localhost:7066/api/Auth/verify-code",
            new
            {
                Email = email,
                Code = code
            });

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<LoginResponse>();

            if (result is not null)
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "authToken", result.Token);
                await JS.InvokeVoidAsync("localStorage.setItem", "userRole", result.Role);
                await JS.InvokeVoidAsync("localStorage.setItem", "userEmail", result.Email);
            }

            message = "Login successful.";
            await Task.Delay(700);
            Nav.NavigateTo("/dashboard");
        }
        else
        {
            message = "Invalid or expired code.";
        }
    }

    public class SendCodeResponse
    {
        public string Message { get; set; } = "";
        public string Code { get; set; } = "";
    }

    public class LoginResponse
    {
        public string Email { get; set; } = "";
        public string Role { get; set; } = "";
        public string Token { get; set; } = "";
    }
}