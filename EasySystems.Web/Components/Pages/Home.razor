@page "/"

<PageTitle>EasySystems</PageTitle>

<div class="home-page">

    <section class="home-hero">
        <div class="hero-content">
            <p class="eyebrow">EasySystems</p>

            <h1>Launch your online store without the technical stress</h1>

            <p class="hero-text">
                We help small businesses create modern online stores with beautiful design,
                payment options, mobile-friendly pages, and a clear launch plan.
            </p>

            <div class="hero-actions">
                <a href="/create-store" class="home-btn-primary">Start your store</a>
                <a href="/register" class="home-btn-secondary">Create account</a>
            </div>

            <div class="trust-row">
                <span>✓ Mobile friendly</span>
                <span>✓ Payment ready</span>
                <span>✓ Built for growth</span>
            </div>
        </div>

        <div class="hero-card">
            <div class="store-preview-top">
                <span></span>
                <span></span>
                <span></span>
            </div>

            <div class="preview-product large"></div>

            <div class="preview-grid">
                <div></div>
                <div></div>
                <div></div>
            </div>

            <div class="preview-line"></div>
            <div class="preview-line short"></div>
        </div>
    </section>

    <section class="home-services">
        <div class="section-heading">
            <p class="eyebrow">What we build</p>
            <h2>Everything you need to start selling online</h2>
        </div>

        <div class="service-grid">
            <div class="service-card">
                <h3>Online stores</h3>
                <p>Modern e-commerce websites where customers can browse products and place orders easily.</p>
            </div>

            <div class="service-card">
                <h3>Online payments</h3>
                <p>We prepare your store for payment options so customers can buy with confidence.</p>
            </div>

            <div class="service-card">
                <h3>Store design</h3>
                <p>A clean and professional design that fits your brand, products, and target customers.</p>
            </div>

            <div class="service-card">
                <h3>Product setup</h3>
                <p>We help structure your products, categories, descriptions, and store pages.</p>
            </div>

            <div class="service-card">
                <h3>Multi-language stores</h3>
                <p>Support for Swedish, Arabic, English, or the languages your customers need.</p>
            </div>

            <div class="service-card">
                <h3>Support after launch</h3>
                <p>We help you after delivery so your store stays clean, stable, and easy to manage.</p>
            </div>
        </div>
    </section>

    <section class="home-process">
        <div class="section-heading">
            <p class="eyebrow">Simple process</p>
            <h2>From idea to online store</h2>
        </div>

        <div class="process-grid">
            <div class="process-step">
                <span>01</span>
                <h3>Choose a package</h3>
                <p>Select the package that fits your business and budget.</p>
            </div>

            <div class="process-step">
                <span>02</span>
                <h3>Answer questions</h3>
                <p>Tell us what you sell, how many products you have, and what features you need.</p>
            </div>

            <div class="process-step">
                <span>03</span>
                <h3>We review your request</h3>
                <p>We check your needs and contact you with the next step.</p>
            </div>

            <div class="process-step">
                <span>04</span>
                <h3>Launch your store</h3>
                <p>Your online store becomes ready for customers.</p>
            </div>
        </div>
    </section>

    <section class="home-cta">
        <h2>Ready to start your online store?</h2>
        <p>Answer a few questions and choose the package that fits your store best.</p>
        <a href="/create-store" class="home-btn-primary">Start now</a>
    </section>

</div>