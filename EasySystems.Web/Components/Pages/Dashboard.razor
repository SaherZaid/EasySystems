@page "/dashboard"
@rendermode InteractiveServer
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Dashboard</PageTitle>

<div class="customer-dashboard">

    <section class="dashboard-hero-pro">

        <div>
            <p class="eyebrow">Customer Dashboard</p>
            <h1>Welcome back</h1>
            <p>Track your projects, progress, and next steps.</p>
        </div>

        <NavLink href="/create-store" class="dashboard-cta">
            Create new request
        </NavLink>

    </section>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="admin-message">@message</div>
    }

    <section class="dashboard-stats">
        <div><span>@requests.Count</span><p>Total</p></div>
        <div><span>@requests.Count(x => x.Status == "Pending")</span><p>Pending</p></div>
        <div><span>@requests.Count(x => x.Status == "In Progress")</span><p>In Progress</p></div>
        <div><span>@requests.Count(x => x.Status == "Completed")</span><p>Completed</p></div>
    </section>

    <section class="dashboard-content-grid">

        <div class="dashboard-main-panel">

            <h2>Your Projects</h2>

            @if (isLoading)
            {
                <div class="admin-message">Loading requests...</div>
            }
            else if (!requests.Any())
            {
                <div class="empty-dashboard">
                    <h2>No requests yet</h2>
                    <p>Create your first store request.</p>

                    <NavLink href="/create-store" class="dashboard-cta">
                        Start now
                    </NavLink>
                </div>
            }
            else
            {
                @foreach (var request in requests)
                {
                    <article class="project-card-pro">

                        <div class="project-card-top">

                            <div>
                                <span class="status-pill @GetStatusClass(request.Status)">
                                    @request.Status
                                </span>

                                <h3>@request.StoreName</h3>
                                <p>@request.BusinessType</p>
                            </div>

                            <div class="package-badge">
                                @request.PackageName
                            </div>

                        </div>

                        <div class="progress-timeline">

                            @foreach (var step in statusSteps)
                            {
                                <div class="timeline-step @(IsStepActive(request.Status, step) ? "active" : "")">
                                    <div class="timeline-dot"></div>
                                    <span>@step</span>
                                </div>
                            }

                        </div>

                        <div class="project-footer-pro">
                            <span>@request.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd")</span>
                            <span>#@request.Id</span>
                        </div>

                    </article>
                }
            }

        </div>

        <aside class="dashboard-side-panel">

            <h2>Next Steps</h2>

            <div class="next-step-box">
                <strong>1. Review</strong>
                <p>We review your request details.</p>
            </div>

            <div class="next-step-box">
                <strong>2. Contact</strong>
                <p>You receive email updates.</p>
            </div>

            <div class="next-step-box">
                <strong>3. Build</strong>
                <p>We begin creating your project.</p>
            </div>

        </aside>

    </section>

</div>

@code {

    private string message = "";
    private bool isLoading = true;

    private List<MyStoreRequestViewModel> requests = new();

    private readonly string[] statusSteps =
    {
        "Pending",
        "In Review",
        "Approved",
        "In Progress",
        "Completed"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadMyRequests();
            StateHasChanged();
        }
    }

    private async Task LoadMyRequests()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        if (string.IsNullOrWhiteSpace(token))
        {
            Nav.NavigateTo("/login");
            return;
        }

        using var req = new HttpRequestMessage(
            HttpMethod.Get,
            "https://localhost:7066/api/StoreRequests/my");

        req.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var response = await Http.SendAsync(req);

        if (response.IsSuccessStatusCode)
        {
            var result =
                await response.Content.ReadFromJsonAsync<List<MyStoreRequestViewModel>>();

            requests = result ?? new();
            message = "";
        }
        else
        {
            message = "Could not load requests.";
        }

        isLoading = false;
    }

    private bool IsStepActive(string currentStatus, string step)
    {
        var currentIndex = Array.IndexOf(statusSteps, currentStatus);
        var stepIndex = Array.IndexOf(statusSteps, step);

        if (currentStatus == "Rejected")
            return step == "Pending";

        return currentIndex >= stepIndex && currentIndex >= 0;
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Pending" => "status-pending",
            "In Review" => "status-review",
            "Approved" => "status-approved",
            "In Progress" => "status-progress",
            "Completed" => "status-completed",
            "Rejected" => "status-rejected",
            _ => "status-pending"
        };
    }

    public class MyStoreRequestViewModel
    {
        public int Id { get; set; }
        public string StoreName { get; set; } = "";
        public string BusinessType { get; set; } = "";
        public string PackageName { get; set; } = "";
        public string Status { get; set; } = "";
        public DateTime CreatedAtUtc { get; set; }
    }
}